
<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Krislåda – Krislägen</title>

  <link rel="stylesheet" href="./styles.css"/>

  <script src="https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/file-saver@2.0.5/dist/FileSaver.min.js"></script>

  <style>
    .category { margin-bottom: 22px; }
    .category h3 { margin: 0 0 6px 0; font-size: 18px; }
    .checklist { list-style:none; padding-left:0; display:grid; gap:8px; }
    .checklist li {
      display:flex; align-items:flex-start; gap:10px;
      padding:10px; background:#0e1620;
      border:1px solid #223042; border-radius:10px;
    }
    .checklist label { cursor:pointer; display:block; }
    .actions-top { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px; }
    .btn { padding:8px 12px; border-radius:8px; cursor:pointer; font-weight:600; }
    .btn-outline {
      border:1px solid #0072ce; background:transparent; color:#0072ce;
    }
    .btn-primary {
      background:#0072ce; color:white; border:1px solid #0072ce;
    }
    .source { font-size:12px; color:#a6b7c8; margin-top:4px; }
  </style>

</head>
<body>

<header>
  <div class="title">
    <a class="back" href="./index.html">← Alla krislägen</a>
    <h1>🎒 Krislåda – Hem­beredskap 7 dagar</h1>
  </div>
</header>

<main>

  <!-- ACTION BUTTONS (TOP) -->
  <section class="section">
    <div class="actions-top">
      <button class="btn btn-outline" id="checkAllBtn">Markera allt</button>
      <button class="btn btn-outline" id="uncheckAllBtn">Avmarkera allt</button>
      <button class="btn btn-outline" id="resetToDefaultBtn">Återställ</button>
      <button class="btn btn-primary" id="exportExcelBtn">Exportera Excel</button>
      <span class="source" id="summary"></span>
    </div>
  </section>

  
  <!-- CONTENT -->
  <section id="krisladaContainer"></section>

  <div class="footer-space"></div>
</main>

<script>
/* ========================
   KRISLÅDA – DATA
======================== */

const STORE_KEY = "kris-halmstad-krislada";

const KRISLADA_DEFAULT = [
  { category:"Vatten 💧", items:[
    { text:"Dricksvatten 3–5 liter per person och dag", done:false },
    { text:"Vattenflaskor/dunkar (livsmedelsgodkända)", done:false },
    { text:"Vattenrening (tabletter/filter/kokmöjlighet)", done:false }
  ]},
  { category:"Mat 🍲", items:[
    { text:"Konserver (gryta, soppa, bönor, fisk)", done:false },
    { text:"Torrvaror (ris, pasta, knäckebröd)", done:false },
    { text:"Nötter, bars, torkad frukt", done:false },
    { text:"Barnmat / specialkost", done:false }
  ]},
  { category:"Värme & Matlagning 🍳", items:[
    { text:"Stormkök + bränsle", done:false },
    { text:"Tändare/tändstickor", done:false },
    { text:"Värmeljus/stearinljus", done:false },
    { text:"Filtar och varma kläder", done:false }
  ]},
  { category:"Energi & Kommunikation 🔦📻", items:[
    { text:"Powerbanks + kablar", done:false },
    { text:"Ficklampa/pannlampa + batterier", done:false },
    { text:"Radio (batteri/vev/sol)", done:false },
    { text:"Utskrivna viktiga nummer", done:false }
  ]},
  { category:"Hygien & Sjukvård 🩹", items:[
    { text:"Första hjälpen-kit", done:false },
    { text:"Läkemedel för minst 7 dagar", done:false },
    { text:"Tvål, våtservetter, toalettpapper", done:false }
  ]},
  { category:"Dokument & Betalning 🪪", items:[
    { text:"ID-handlingar/kopior", done:false },
    { text:"Kontanter i små valörer", done:false }
  ]},
  { category:"Övrigt 🧰", items:[
    { text:"Multiverktyg/kniv, silvertejp, snöre", done:false },
    { text:"Reflexvästar, batteribank extra", done:false }
  ]}
];

/* ========================
   STORAGE
======================== */

function loadState(){
  try {
    const raw = localStorage.getItem(STORE_KEY);
    if(!raw) return structuredClone(KRISLADA_DEFAULT);
    const p = JSON.parse(raw);
    if(!Array.isArray(p)) return structuredClone(KRISLADA_DEFAULT);
    return p;
  } catch {
    return structuredClone(KRISLADA_DEFAULT);
  }
}

function saveState(state){
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
}

let state = loadState();


/* ========================
   RENDER
======================== */

function render(){
  const container = document.getElementById("krisladaContainer");
  const summary = document.getElementById("summary");

  let total = 0, done = 0;

  container.innerHTML = state.map((cat, ci) => {
    const items = cat.items.map((it, ii) => {
      total++;
      if(it.done) done++;

      return `
        <li>
          <input type="checkbox" id="i_${ci}_${ii}" ${it.done ? "checked":""}
            onchange="toggleItem(${ci},${ii},this.checked)">
          <label for="i_${ci}_${ii}">${it.text}</label>
        </li>`;
    }).join("");

    return `
      <div class="category">
        <h3>${cat.category}</h3>
        <ul class="checklist">${items}</ul>
      </div>`;
  }).join("");

  summary.textContent = `${done}/${total} klara`;
}

function toggleItem(ci, ii, val){
  state[ci].items[ii].done = val;
  saveState(state);
  render();
}


/* ========================
   BUTTON ACTIONS
======================== */

document.getElementById("checkAllBtn").onclick = () => {
  state.forEach(c => c.items.forEach(i => i.done = true));
  saveState(state);
  render();
};

document.getElementById("uncheckAllBtn").onclick = () => {
  state.forEach(c => c.items.forEach(i => i.done = false));
  saveState(state);
  render();
};

document.getElementById("resetToDefaultBtn").onclick = () => {
  if(confirm("Återställa Krislådan till originalinnehåll?")){
    state = structuredClone(KRISLADA_DEFAULT);
    saveState(state);
    render();
  }
};


/* ========================
   EXCEL EXPORT
======================== */

document.getElementById("exportExcelBtn").onclick = async () => {
  const wb = new ExcelJS.Workbook();
  wb.created = new Date();
  const ws = wb.addWorksheet("Krislåda");

  ws.addRow(["Krislåda – Hem­beredskap"]).font = { bold:true, size:16 };
  ws.addRow([]);

  state.forEach(cat => {
    ws.addRow([cat.category]).font = { bold:true };
    ws.addRow(["Post", "Klar"]);

    cat.items.forEach(it => {
      ws.addRow([it.text, it.done ? "Ja" : "Nej"]);
    });

    ws.addRow([]);
  });

  const buf = await wb.xlsx.writeBuffer();
  saveAs(new Blob([buf]), "krislada.xlsx");
};


/* ========================
   INIT
======================== */

render();

</script>

</body>
</html>
